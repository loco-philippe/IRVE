{
    "$id": "https://github.com/loco-philippe/IRVE/blob/main/OCPI/source/schema.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Qualicharge_OCPI_Tariff",
    "description": "This schema defines the structure and validation rules for OCPI Tariff objects used in the Qualicharge platform. It includes properties of OCPI 2.2 and OCPI 2.3 and requires only the properties that are applicable to the Qualicharge platform. The schema ensures that OCPI Tariff data adheres to the required format and constraints.",
    "type": "object",
    "required": [
        "country_code",
        "party_id",
        "id",
        "elements",
        "last_updated"
    ],
    "properties": {
        "country_code": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "ISO-3166 alpha-2 country code."
        },
        "party_id": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "CPO ID"
        },
        "id": {
            "type": "string",
            "maxLength": 36,
            "description": "Unique tariff ID"
        },
        "currency": {
            "const": "EUR",
            "description": "ISO-4217 currency code of Europa"
        },
        "tariff_alt_text": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "language",
                    "text"
                ],
                "properties": {
                    "language": {
                        "type": "string",
                        "maxLength": 2
                    },
                    "text": {
                        "type": "string",
                        "maxLength": 512
                    }
                }
            }
        },
        "tariff_alt_url": {
            "type": "string",
            "format": "uri",
            "maxLength": 255
        },
        "type": {
            "enum": [
                "AD_HOC_PAYMENT",
                "PROFILE_CHEAP",
                "PROFILE_FAST",
                "PROFILE_GREEN",
                "REGULAR"
            ],
            "description": "AD_HOC_PAYMENT is the type requested"
        },
        "start_date_time": {
            "type": "string",
            "format": "date-time"
        },
        "end_date_time": {
            "type": "string",
            "format": "date-time"
        },
        "energy_mix": {
            "type": "object",
            "required": [
                "is_green_energy"
            ],
            "properties": {
                "is_green_energy": {
                    "type": "boolean"
                },
                "supplier_name": {
                    "type": "string",
                    "maxLength": 64
                },
                "energy_product_name": {
                    "type": "string",
                    "maxLength": 64
                },
                "energy_sources": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "source",
                            "percentage"
                        ],
                        "properties": {
                            "source": {
                                "enum": [
                                    "NUCLEAR",
                                    "GENERAL_FOSSIL",
                                    "COAL",
                                    "GAS",
                                    "GENERAL_GREEN",
                                    "SOLAR",
                                    "WIND",
                                    "WATER"
                                ]
                            },
                            "percentage": {
                                "type": "number",
                                "minimum": 0,
                                "maximum": 100
                            }
                        }
                    }
                },
                "environ_impact": {
                    "type": "object",
                    "required": [
                        "category",
                        "amount"
                    ],
                    "properties": {
                        "category": {
                            "enum": [
                                "NUCLEAR_WASTE",
                                "CARBON_DIOXIDE"
                            ]
                        },
                        "amount": {
                            "type": "number"
                        }
                    }
                }
            }
        },
        "last_updated": {
            "type": "string",
            "format": "date-time"
        },
        "tax_included": {
            "description": "OCPI 2.3 format",
            "enum": [
                "YES",
                "NO",
                "N/A"
            ]
        },
        "preauthorize_amount": {
            "description": "OCPI 2.3 format",
            "type": "number"
        },
        "min_price": {
            "anyOf": [
                {
                    "description": "OCPI 2.2 format",
                    "type": "object",
                    "required": [
                        "excl_vat"
                    ],
                    "properties": {
                        "excl_vat": {
                            "type": "number"
                        },
                        "incl_vat": {
                            "type": "number"
                        }
                    }
                },
                {
                    "description": "OCPI 2.3 format",
                    "type": "object",
                    "required": [
                        "before_taxes"
                    ],
                    "properties": {
                        "before_taxes": {
                            "type": "number"
                        },
                        "after_taxes": {
                            "type": "number"
                        }
                    }
                }
            ]
        },
        "max_price": {
            "anyOf": [
                {
                    "description": "OCPI 2.2 format",
                    "type": "object",
                    "required": [
                        "excl_vat"
                    ],
                    "properties": {
                        "excl_vat": {
                            "type": "number"
                        },
                        "incl_vat": {
                            "type": "number"
                        }
                    }
                },
                {
                    "description": "OCPI 2.3 format",
                    "type": "object",
                    "required": [
                        "before_taxes"
                    ],
                    "properties": {
                        "before_taxes": {
                            "type": "number"
                        },
                        "after_taxes": {
                            "type": "number"
                        }
                    }
                }
            ]
        },
        "elements": {
            "type": "array",
            "minItems": 1,
            "items": {
                "description": "TariffElement",
                "type": "object",
                "required": [
                    "price_components"
                ],
                "properties": {
                    "price_components": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": [
                                "type",
                                "price",
                                "step_size"
                            ],
                            "properties": {
                                "type": {
                                    "description": "OCPI types + additional type for congestion pricing",
                                    "enum": [
                                        "ENERGY",
                                        "FLAT",
                                        "PARKING_TIME",
                                        "TIME",
                                        "CONGESTION_TIME"
                                    ]
                                },
                                "price": {
                                    "type": "number"
                                },
                                "vat": {
                                    "type": "number",
                                    "minimum": 19.9,
                                    "maximum": 20.1
                                   },
                                "step_size": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            }
                        }
                    },
                    "restrictions": {
                        "type": "object",
                        "properties": {
                            "start_time": {
                                "type": "string",
                                "maxLength": 5,
                                "minLength": 5,
                                "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
                            },
                            "end_time": {
                                "type": "string",
                                "maxLength": 5,
                                "minLength": 5,
                                "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
                            },
                            "start_date": {
                                "type": "string",
                                "maxLength": 10,
                                "minLength": 10,
                                "format": "date"
                            },
                            "end_date": {
                                "type": "string",
                                "format": "date"
                            },
                            "min_kwh": {
                                "type": "number"
                            },
                            "max_kwh": {
                                "type": "number"
                            },
                            "min_current": {
                                "type": "number"
                            },
                            "max_current": {
                                "type": "number"
                            },
                            "min_power": {
                                "type": "number"
                            },
                            "max_power": {
                                "type": "number"
                            },
                            "min_duration": {
                                "type": "integer"
                            },
                            "max_duration": {
                                "type": "integer"
                            },
                            "day_of_week": {
                                "type": "array",
                                "items": {
                                    "enum": [
                                        "MONDAY",
                                        "TUESDAY",
                                        "WEDNESDAY",
                                        "THURSDAY",
                                        "FRIDAY",
                                        "SATURDAY",
                                        "SUNDAY"
                                    ]
                                }
                            },
                            "reservation": {
                                "enum": [
                                    "RESERVATION",
                                    "RESERVATION_EXPIRES"
                                ]
                            },
                            "min_vehicle_soc": {
                                "description": "additional type for congestion pricing",
                                "type": "integer"
                            },
                            "min_congestion_threshold": {
                                "description": "additional type for congestion pricing",
                                "type": "integer"
                            }
                        }
                    }
                }
            }
        }
    }
}