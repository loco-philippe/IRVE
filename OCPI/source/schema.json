{
    "$id": "https://www.jsonschemavalidator.net/s/9jXn0qs6",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Qualicharge_OCPI_Tariff",
    "description": "This schema defines the structure and validation rules for OCPI Tariff objects used in the Qualicharge platform. It includes properties of OCPI 2.2 and OCPI 2.3 and requires only the properties that are applicable to the Qualicharge platform. The schema ensures that OCPI Tariff data adheres to the required format and constraints.",
    "type": "object",
    "required": [
        "id",
        "elements",
        "last_updated"
    ],
    "properties": {
        "country_code": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "ISO-3166 alpha-2 country code"
        },
        "party_id": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "CPO ID"
        },
        "id": {
            "type": "string",
            "maxLength": 36,
            "description": "Unique tariff ID"
        },
        "currency": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "ISO-4217 currency code (ex: EUR)"
        },
        "tariff_alt_text": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "language": {
                        "type": "string"
                    },
                    "text": {
                        "type": "string"
                    }
                }
            }
        },
        "start_date_time": {
            "type": "string",
            "format": "date-time"
        },
        "end_date_time": {
            "type": "string",
            "format": "date-time"
        },
        "last_updated": {
            "type": "string",
            "format": "date-time"
        },
        "tax_included": {
            "enum": [
                "YES",
                "NO",
                "N/A"
            ]
        },
        "min_price": {
            "anyOf": [
                {
                    "description": "OCPI 2.2 format",
                    "type": "number"
                },
                {
                    "description": "OCPI 2.3 format",
                    "type": "object",
                    "required": [
                        "before_taxes"
                    ],
                    "properties": {
                        "before_taxes": {
                            "type": "number"
                        },
                        "after_taxes": {
                            "type": "number"
                        }
                    }
                }
            ]
        },
        "max_price": {
            "anyOf": [
                {
                    "description": "OCPI 2.2 format",
                    "type": "object",
                    "required": [
                        "excl_vat"
                    ],
                    "properties": {
                        "excl_vat": {
                            "type": "number"
                        },
                        "incl_vat": {
                            "type": "number"
                        }
                    }
                },
                {
                    "description": "OCPI 2.3 format",
                    "type": "object",
                    "required": [
                        "before_taxes"
                    ],
                    "properties": {
                        "before_taxes": {
                            "type": "number"
                        },
                        "after_taxes": {
                            "type": "number"
                        }
                    }
                }
            ]
        },
        "elements": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "price_components"
                ],
                "properties": {
                    "price_components": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": [
                                "type",
                                "price"
                            ],
                            "properties": {
                                "type": {
                                    "description": "additional type for congestion pricing",
                                    "enum": [
                                        "ENERGY",
                                        "FLAT",
                                        "PARKING_TIME",
                                        "TIME",
                                        "CONGESTION_TIME"
                                    ]
                                },
                                "price": {
                                    "type": "number"
                                },
                                "vat": {
                                    "type": "number"
                                },
                                "step_size": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            }
                        }
                    },
                    "restrictions": {
                        "type": "object",
                        "properties": {
                            "start_time": {
                                "type": "string",
                                "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
                            },
                            "end_time": {
                                "type": "string",
                                "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
                            },
                            "start_date": {
                                "type": "string",
                                "format": "date"
                            },
                            "end_date": {
                                "type": "string",
                                "format": "date"
                            },
                            "min_kwh": {
                                "type": "number"
                            },
                            "max_kwh": {
                                "type": "number"
                            },
                            "min_current": {
                                "type": "number"
                            },
                            "max_current": {
                                "type": "number"
                            },
                            "min_power": {
                                "type": "number"
                            },
                            "max_power": {
                                "type": "number"
                            },
                            "min_duration": {
                                "type": "integer"
                            },
                            "max_duration": {
                                "type": "integer"
                            },
                            "day_of_week": {
                                "type": "array",
                                "items": {
                                    "enum": [
                                        "MONDAY",
                                        "TUESDAY",
                                        "WEDNESDAY",
                                        "THURSDAY",
                                        "FRIDAY",
                                        "SATURDAY",
                                        "SUNDAY"
                                    ]
                                }
                            },
                            "reservation": {
                                "enum": [
                                    "RESERVATION",
                                    "RESERVATION_EXPIRES"
                                ]
                            },
                            "min_vehicle_soc": {
                                "description": "additional type for congestion pricing",
                                "type": "integer"
                            },
                            "min_congestion_threshold": {
                                "description": "additional type for congestion pricing",
                                "type": "integer"
                            }
                        }
                    }
                }
            }
        }
    }
}